{
  "name": "apothecary",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Semantic herb search web app",
  "scripts": {
    "ingest": "node scripts/ingest.js",
    "ingest:prod": "node scripts/ingest.js prod",
    "enrich": "node scripts/enrich_herbs.js",
    "compare": "node scripts/compare_herbs.js",
    "functions": "npx supabase functions serve --env-file .env --no-verify-jwt",
    "client": "cd client && npm run dev",
    "dev": "npm-run-all --parallel functions client",
    "build": "cd client && npm run build",
    "deploy": "npx supabase functions deploy search nutritionist --project-ref donareoeoobqmomarisf"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.7",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
