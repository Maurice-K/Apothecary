{
  "name": "apothecary",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Semantic herb search web app",
  "scripts": {
    "ingest": "node scripts/ingest.js",
    "compare": "node scripts/compare_herbs.js",
    "dev:functions": "npx supabase functions serve --env-file .env --no-verify-jwt",
    "dev:client": "cd client && npm run dev",
    "dev": "npm-run-all --parallel dev:functions dev:client",
    "build": "cd client && npm run build",
    "deploy:search": "npx supabase functions deploy search",
    "deploy:nutritionist": "npx supabase functions deploy nutritionist",
    "deploy": "npm-run-all deploy:search deploy:nutritionist"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "dotenv": "^16.4.7",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
